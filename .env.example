# Plantilla — copiar a .env y rellenar. NO poner keys reales aqui.

# Secret key backend (sk_live_... o sk_test_...)
FINTOC_SECRET_KEY=TU_SECRET_KEY_FINTOC

# Key publica del widget (pk_live_... o pk_test_...)
FINTOC_PUBLIC_KEY=TU_PUBLIC_KEY_FINTOC

# Cuenta conectada
FINTOC_LINK_TOKEN=link_token_xxxxxxxxxxxxxxxxxxxx
FINTOC_ACCOUNT_ID=acc_xxxxxxxxxxxxxxxxxxxx
